{
  "expo": {
    "name": "Pinch",
    "slug": "pinch",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "pinch",
    "userInterfaceStyle": "automatic",
    "androidStatusBar": {
      "backgroundColor": "#F4F1F8",
      "barStyle": "dark-content",
      "translucent": false
    },
    "ios": {
      "icon": "./assets/expo.icon",
      "usesAppleSignIn": true,
      "bundleIdentifier": "com.pinch.myapp",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.pinch.myapp",
      "backgroundColor": "#F4F1F8",
      "adaptiveIcon": {
        "backgroundColor": "#F4F1F8",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F4F1F8",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ],
      "expo-localization",
      "expo-apple-authentication",
      [
        "expo-web-browser",
        {
          "experimentalLauncherActivity": false
        }
      ],
      [
        "expo-share-intent",
        {
          "androidIntentFilters": [
            "text/*"
          ],
          "iosActivationRules": {
            "NSExtensionActivationSupportsText": true,
            "NSExtensionActivationSupportsWebURLWithMaxCount": 1,
            "NSExtensionActivationSupportsWebPageWithMaxCount": 1
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Pinch needs access to your photos so you can set a profile picture.",
          "cameraPermission": "Pinch needs access to your camera so you can take a profile picture."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "buildToolsVersion": "35.0.0",
            "useLegacyPackaging": false,
            "enableMinifyInReleaseBuilds": true,
            "extraProguardRules": "-keepattributes SourceFile,LineNumberTable\n-keepattributes *Annotation*\n-keep class com.swmansion.reanimated.** { *; }\n-keep class com.facebook.react.turbomodule.** { *; }"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "owner": "yardenfa",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "58f56906-4b2d-49ca-9e87-a706b5d7cf1f"
      },
      "legalBaseUrl": "https://yardenfarag.github.io/Recipe_app",
      "supportEmail": "yarden.farag@gmail.com"
    }
  }
}
