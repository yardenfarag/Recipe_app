EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_KEY=your_publishable_key

# Comma-separated emails that can open Settings → Admin usage tracker
# (also set profiles.is_admin = true for those users after migration 0009)
EXPO_PUBLIC_ADMIN_EMAILS=you@example.com

# Public legal site (GitHub Pages from /legal). No trailing slash.
EXPO_PUBLIC_LEGAL_BASE_URL=https://yardenfarag.github.io/Recipe_app
EXPO_PUBLIC_SUPPORT_EMAIL=you@example.com

# Server-side only — set these in Supabase Edge Function secrets, not in the Expo app
# GEMINI_API_KEY=your_gemini_api_key
# GEMINI_FAST_MODEL=gemini-3.1-flash-lite
# GEMINI_MODEL=gemini-3.5-flash
# For Sign in with Apple token revoke on account deletion (optional until iOS ship):
# APPLE_CLIENT_ID=com.pinch.myapp
# APPLE_TEAM_ID=XXXXXXXXXX
# APPLE_KEY_ID=XXXXXXXXXX
# APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
